                "--dart-define=API_BASE_URL=http://192.168.1.192:8080",
                "--dart-define=GOOGLE_MAPS_API_KEY="
            ]
        },
        {
            "name": "patrol_mobile (debug mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "toolArgs": [
                "--dart-define=API_BASE_URL=http://192.168.1.192:8080",
                "--dart-define=GOOGLE_MAPS_API_KEY="
            ]
        },
        {
            "name": "patrol_mobile (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": [
                "--dart-define=API_BASE_URL=http://192.168.1.192:8080",
                "--dart-define=GOOGLE_MAPS_API_KEY="
