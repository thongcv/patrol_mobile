    "version": "0.2.0",
    "configurations": [
        {
            "name": "patrol_mobile",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define=API_BASE_URL=http://192.168.1.192:8080",
                "--dart-define=GOOGLE_MAPS_API_KEY="
            ]
        },
        {
            "name": "patrol_mobile (profile mode)",
            "request": "launch",
            "type": "dart",
